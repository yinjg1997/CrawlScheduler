# Database
DATABASE_URL=sqlite+aiosqlite:///./data/crawlscheduler.db

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=True

# Timezone
TIMEZONE=Asia/Shanghai

# Paths
LOGS_DIR=./data/logs

# Scheduler
SCHEDULER_ENABLED=True

# Security
SECRET_KEY=your-secret-key-change-this-in-production-please
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256
